generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String      @id @default(cuid())
  clerkId     String      @unique
  username    String?
  characters  Character[]
  ship        Ship?
  currentTurn Int         @default(1)
  createdAt   DateTime    @default(now())
}

model Character {
  id             String           @id @default(cuid())
  name           String
  userId         String?
  user           User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  strength       Int
  dexterity      Int
  endurance      Int
  intelligence   Int
  education      Int
  socialStanding Int
  credits        Int              @default(0)
  sheet          Json?
  currentWorldId String?
  currentWorld   World?           @relation(fields: [currentWorldId], references: [id])
  skills         CharacterSkill[]
  locationLog    LocationLog[]
  crewAssignment ShipCrew?
  shipPassage    ShipPassenger?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model CharacterSkill {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  name        String
  level       Int
}

model LocationLog {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  worldId     String
  world       World     @relation(fields: [worldId], references: [id])
  arrivedAt   DateTime  @default(now())
}

model Sector {
  id           String  @id @default(cuid())
  abbreviation String  @unique
  name         String
  gridX        Int
  gridY        Int
  milieu       String  @default("M1105")
  worlds       World[]
}

model World {
  id             String        @id @default(cuid())
  hex            String
  hexX           Int
  hexY           Int
  name           String
  sectorId       String
  sector         Sector        @relation(fields: [sectorId], references: [id])
  subsector      String
  starport       String
  size           String
  atmosphere     String
  hydrographics  String
  population     String
  government     String
  lawLevel       String
  techLevel      String
  uwpRaw         String
  remarks        String[]
  travelZone     String?
  allegiance     String?
  stellar        String[]
  gasGiants      Int           @default(0)
  belts          Int           @default(0)
  worldsInSystem Int           @default(0)
  characters     Character[]
  locationLogs   LocationLog[]
  dockedShips    Ship[]        @relation("ShipCurrentWorld")
  inboundShips   Ship[]        @relation("ShipDestinationWorld")
  cargoOrigins   CargoLot[]

  @@unique([sectorId, hex])
}

model Ship {
  id                  String          @id @default(cuid())
  name                String
  type                String
  jumpRating          Int
  isMortgaged         Boolean         @default(true)
  mortgagePaid        Int             @default(0)
  status              String          @default("docked")
  sheet               Json?
  currentWorldId      String?
  currentWorld        World?          @relation("ShipCurrentWorld", fields: [currentWorldId], references: [id])
  destinationWorldId  String?
  destinationWorld    World?          @relation("ShipDestinationWorld", fields: [destinationWorldId], references: [id])
  jumpArrivesTurn     Int?
  userId              String?         @unique
  user                User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  crew                ShipCrew[]
  passengers          ShipPassenger[]
  cargo               CargoLot[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model ShipCrew {
  id              String     @id @default(cuid())
  shipId          String
  ship            Ship       @relation(fields: [shipId], references: [id], onDelete: Cascade)
  characterId     String?    @unique
  character       Character? @relation(fields: [characterId], references: [id], onDelete: Cascade)
  npcName         String?
  role            String
  isOwnerOperator Boolean    @default(false)
  monthlySalary   Int        @default(0)
}

model ShipPassenger {
  id          String    @id @default(cuid())
  shipId      String
  ship        Ship      @relation(fields: [shipId], references: [id], onDelete: Cascade)
  characterId String    @unique
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  passage     String
}

model CargoLot {
  id            String   @id @default(cuid())
  shipId        String
  ship          Ship     @relation(fields: [shipId], references: [id], onDelete: Cascade)
  commodity     String
  tons          Int
  purchasePrice Int
  originWorldId String
  originWorld   World    @relation(fields: [originWorldId], references: [id])
  acquiredAt    DateTime @default(now())
}
